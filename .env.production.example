# Hosting Guard - Production Environment Variables
# -----------------------------------------------
# COPIA ESTE ARCHIVO A .env.production Y EDITA LOS VALORES REALES

# Entorno
PORT=8000
SECRET_KEY=cambia-este-valor-aleatorio-por-uno-seguro

# Flags de Gobernanza
ENABLE_AI_ADVISORY=true
ENABLE_ACTION_EXECUTION=false # Activar solo tras validación humana robusta

# IA API Keys (Puedes usar una o ambas dependiendo del orquestador)
OPENAI_API_KEY=tu-openai-key-aqui
CLAUDE_API_KEY=tu-claude-key-aqui

# Rutas de Base de Datos (Relativas al directorio de la app)
# Por defecto se encuentran en la raíz del proyecto
AUDIT_DB_PATH=audit_events.sqlite
CONFIG_DB_PATH=tenant_configs.sqlite
