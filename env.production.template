# .env.production — copy to server as .env.production and fill in values
# NEVER commit this file with real secrets.

# ── Core ──────────────────────────────────────────────────────────────────────
APP_ENV=production
JWT_SECRET=<generate with: openssl rand -hex 32>
PORT=8000
APP_URL=https://hostingguard.lat

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@postgres:5432/hostingguard
REDIS_URL=redis://redis:6379/0

# ── Email (Zoho Mail SMTP) ────────────────────────────────────────────────────
# Zoho Mail — STARTTLS en puerto 587 (recomendado) o SSL en 465.
# Documentación: https://www.zoho.com/mail/help/zoho-smtp.html
#
# Pasos en Zoho:
#   1. Zoho Mail → Configuración → Seguridad → Contraseñas de aplicación
#   2. Crear una "App Password" específica para HostingGuard
#   3. Usar esa contraseña en SMTP_PASS (NO tu contraseña de Zoho)
#
# Nota: SMTP_USER = la dirección de email completa de Zoho
#       FROM_EMAIL = puede ser la misma o un alias verificado
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=noreply@hostingguard.lat
SMTP_PASS=<app-password-from-zoho>
FROM_EMAIL=noreply@hostingguard.lat

# ── Feature flags ────────────────────────────────────────────────────────────
ENABLE_AI_ADVISORY=false
ENABLE_ACTION_EXECUTION=false

# ── LLM (only needed if ENABLE_AI_ADVISORY=true) ─────────────────────────────
# OPENAI_API_KEY=
# CLAUDE_API_KEY=
